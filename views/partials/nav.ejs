<header id="navbar"
  class="sticky top-0 z-50 bg-[#0E0D13]/95 backdrop-blur-md border-b border-[#2D2A37] transition-all duration-300 ease-out">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">

    <!-- LOGO -->
    <a href="/" class="text-3xl font-extrabold tracking-tight ui-action">
      <span class="text-white">Livin</span><span class="text-[#8C5FF6]">Go</span>
    </a>

    <!-- CENTER NAV (desktop) -->
    <nav class="hidden md:block">
      <ul class="flex space-x-8">
        <li><a href="/" class="navlink ui-action">Home</a></li>

        <% if (isLoggedIn) { %>
          <% if (user && user.userType === 'host') { %>
            <!-- Host: host-specific links -->
            <li><a href="/host/host-home-list" class="navlink ui-action">Host Homes</a></li>
            <li><a href="/host/add-home" class="navlink ui-action">Add Home</a></li>
          <% } else { %>
            <!-- Guest (or other): guest-specific links -->
            <li><a href="/homes" class="navlink ui-action">Listed Homes</a></li>
            <li><a href="/bookings" class="navlink ui-action">Bookings</a></li>
          <% } %>
        <% } %>
      </ul>
    </nav>

    <!-- RIGHT ACTIONS -->
    <div class="flex items-center space-x-5">

      <% if (isLoggedIn) { %>
        <!-- Right-side CTAs for logged-in users: show Become a Host and Wishlist only to non-hosts -->
        <% if (!user || user.userType !== 'host') { %>
          <a href="/host/add-home"
            class="hidden md:inline-block bg-gradient-to-r from-[#8C5FF6] to-[#F43F63] text-white font-semibold px-5 py-2 rounded-full shadow-md ui-action">
            Become a Host
          </a>
          <a href="/favourite" class="hidden md:inline-block ui-action">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" class="w-6 h-6 text-[#E5E3F3] hover:text-[#F43F63]"
              viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.645 1.145-4.312 2.795C11.333 4.895 9.623 3.75 7.688 3.75 5.099 3.75 3 5.765 3 8.25c0 7.22 9 11.25 9 11.25s9-4.03 9-11.25z" />
            </svg>
          </a>
        <% } %>
      <% } %>

          <!-- PROFILE DROPDOWN -->
          <% if(isLoggedIn){ %>
            <div class="relative group">
              <button
                class="w-10 h-10 rounded-full bg-[#18171F] border-[2.5px] border-[#8C5FF6] shadow-[0_0_6px_#8C5FF640] flex items-center justify-center font-bold text-[#E5E3F3] text-lg ui-action">U
              </button>

              <div
                class="absolute right-0 mt-2 w-52 bg-[#18171F] border border-[#2D2A37] rounded-xl shadow-xl py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 ease-out">
                <a href="/profile" class="block px-4 py-2 text-[#E5E3F3] hover:bg-[#201F2A] ui-action">My Profile</a>
                <a href="/bookings" class="block px-4 py-2 text-[#E5E3F3] hover:bg-[#201F2A] ui-action">My Bookings</a>
                <a href="/favourite" class="block px-4 py-2 text-[#E5E3F3] hover:bg-[#201F2A] ui-action">My Wishlist</a>
                <% if (user && user.userType === 'host') { %>
                  <a href="/host/host-home-list" class="block px-4 py-2 text-[#E5E3F3] hover:bg-[#201F2A] ui-action">Host
                    Dashboard</a>
                <% } %>
                <form action="/logout" method="POST">
                  <button type="submit"
                    class="w-full text-left px-4 py-2 text-[#F97373] hover:bg-[#201F2A] ui-action">Logout</button>
                </form>
              </div>
            </div>
            <% } else { %>

              <!-- LOGIN BUTTON -->
              <a href="/signup"
                class="bg-gradient-to-r from-[#8C5FF6] to-[#F43F63] text-white font-semibold px-5 py-2 rounded-full shadow-md ui-action">
                signup
              </a>
              <% } %>

                <!-- MOBILE MENU BUTTON -->
                <button id="mobileMenuBtn" class="md:hidden text-[#E5E3F3] ui-action">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                  </svg>
                </button>
    </div>
  </div>

  <!-- MOBILE MENU -->
  <div id="mobileMenu"
    class="hidden md:hidden px-6 pb-5 bg-[#0E0D13] border-t border-[#2D2A37] transition-all duration-200 ease-out">
    <ul class="flex flex-col space-y-4 text-[#E5E3F3] font-medium pt-4">
      <li><a href="/" class="ui-action">Home</a></li>
      <% if (isLoggedIn) { %>
        <% if (user && user.userType === 'host') { %>
          <!-- Host mobile menu -->
          <li><a href="/host/host-home-list" class="ui-action">Host Homes</a></li>
          <li><a href="/host/add-home" class="ui-action">Add Home</a></li>
        <% } else { %>
          <!-- Guest mobile menu -->
          <li><a href="/homes" class="ui-action">Homes</a></li>
          <li><a href="/favourite" class="ui-action">Wishlist</a></li>
          <li><a href="/host/add-home" class="ui-action">Become a Host</a></li>
        <% } %>

        <!-- Common for logged-in users -->
        <li><a href="/bookings" class="ui-action">Bookings</a></li>
        <li><a href="/profile" class="ui-action">Profile</a></li>
      <% } %>

      <% if (isLoggedIn) { %>
        <form action="/logout" method="POST">
          <button type="submit" class="text-left w-full text-[#F97373] ui-action">Logout</button>
        </form>
      <% } else { %>
        <li><a href="/signup" class="ui-action">signup</a></li>
      <% } %>
    </ul>
  </div>
</header>

<script>
  document.getElementById("mobileMenuBtn").addEventListener("click", () => {
    document.getElementById("mobileMenu").classList.toggle("hidden");
  });
</script>