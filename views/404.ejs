<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Page Not Found | LivinGo</title>

  <link rel="stylesheet" href="/output.css" />
  <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />

  <!-- Lottie Animation -->
  <script src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>
</head>

<body class="bg-[#0E0D13] text-[#E5E3F3] min-h-screen flex flex-col transition-all duration-300">

  <!-- NAVBAR -->
  <%- include('./partials/nav') %>

  <!-- MAIN -->
  <main class="relative flex flex-col items-center justify-center flex-1 text-center px-4 sm:px-6 gap-4 md:gap-6">

    <!-- Stars -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="star-layer layer1"></div>
      <div class="star-layer layer2"></div>
      <div class="star-layer layer3"></div>
    </div>

    <!-- Glow -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_#8C5FF620,_transparent_65%)] pointer-events-none"></div>

    <!-- Animation (Responsive size) -->
    <div class="flex justify-center items-center w-full">
      <lottie-player
        src="https://lottie.host/6f3aae03-53af-4939-aa28-61978ad09db7/VBdhLz1exy.json"
        background="transparent"
        speed="1"
        class="w-[180px] h-[180px] sm:w-[220px] sm:h-[220px] md:w-[260px] md:h-[260px]"
        autoplay
        loop>
      </lottie-player>
    </div>

    <!-- TEXT -->
    <div class="mt-[-10px] sm:mt-[-20px] md:mt-[-40px] space-y-3 px-2">
      <h2 class="text-2xl sm:text-3xl md:text-5xl font-extrabold tracking-tight leading-snug">
        Looks like you're lost in space 🚀
      </h2>

      <p class="text-sm sm:text-base md:text-lg max-w-xl mx-auto text-[#C9C5D4] leading-relaxed px-1">
        The page you're searching for doesn't exist — but your next perfect stay does.
      </p>
    </div>

    <!-- BUTTON (mobile friendly) -->
    <a href="/"
      class="mt-3 sm:mt-4 bg-gradient-to-r from-[#8C5FF6] to-[#F43F63] text-white font-semibold
      px-6 py-3 sm:px-8 sm:py-3 rounded-full shadow-lg shadow-[#8C5FF640]
      hover:shadow-[#8C5FF680] hover:scale-[1.06] active:scale-[0.97]
      transition-all duration-300 select-none touch-manipulation
      mb-20 sm:mb-32 md:mb-48">
      Back to Home
    </a>

  </main>

  <!-- FOOTER -->
  <%- include('./partials/footer') %>
</body>
</html>
