<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign Up | LivinGo</title>
  <link rel="stylesheet" href="/output.css" />
  <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />

  <style>
    .signup-shell {
      box-shadow: 0 0 40px #000000aa, 0 0 60px #8C5FF620;
      background:
        radial-gradient(circle at top left, #8C5FF610, transparent 55%),
        radial-gradient(circle at bottom right, #F43F6330, transparent 55%),
        #14131c;
    }

    .signup-hero {
      background:
        radial-gradient(circle at top, #8C5FF640, transparent 65%),
        radial-gradient(circle at bottom, #F9737330, transparent 60%),
        #151321;
    }

    .field-shell:focus-within {
      box-shadow: 0 0 12px #8C5FF640;
      border-color: #8C5FF6;
    }

    .strength-weak {
      background: linear-gradient(90deg, #F97373, #FB923C);
    }

    .strength-medium {
      background: linear-gradient(90deg, #EAB308, #34D399);
    }

    .strength-strong {
      background: linear-gradient(90deg, #22C55E, #4ADE80);
    }

    .role-card-active {
      border-color: #8C5FF6;
      background: radial-gradient(circle at top left, #8C5FF620, transparent 60%), #1b1826;
      box-shadow: 0 0 14px #8C5FF640;
      transform: translateY(-2px) scale(1.02);
    }

    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      20% { transform: translateX(-6px); }
      40% { transform: translateX(6px); }
      60% { transform: translateX(-4px); }
      80% { transform: translateX(4px); }
    }
  </style>
</head>

<body class="bg-[#0E0D13] text-[#E5E3F3] min-h-screen flex flex-col">

  <%- include('../partials/nav') %>

  <main class="flex-1 flex items-center justify-center px-4 py-10">
    <div
      class="signup-shell w-full max-w-5xl rounded-3xl border border-[#2D2A37] overflow-hidden grid grid-cols-1 md:grid-cols-[1.1fr_1.2fr]">

      <!-- LEFT SIDE -->
      <div class="signup-hero hidden md:flex flex-col justify-between p-8 border-r border-[#2D2A37]">
        <div class="space-y-4">
          <p class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-[#C9C5D4]">
            <span class="h-[2px] w-8 bg-gradient-to-r from-[#8C5FF6] to-[#F43F63] rounded-full"></span>
            Welcome to LivinGo
          </p>
          <h1 class="text-3xl font-extrabold leading-tight">
            Host smarter. <span class="text-[#8C5FF6]">Stay better.</span>
          </h1>
          <p class="text-sm text-[#B9B7C6] max-w-sm">
            Manage premium stays in vibrant cityscapes or peaceful getaways.
          </p>
        </div>

        <div class="mt-6 flex-1 flex items-end justify-center">
          <img
            src="https://images.unsplash.com/photo-1528909514045-2fa4ac7a08ba?auto=format&w=900&q=80"
            class="w-full max-w-xs rounded-2xl border border-[#2D2A37] object-cover shadow-lg shadow-[#000000aa]"
            alt="City illustration" />
        </div>
      </div>

      <!-- RIGHT SIDE -->
      <div class="bg-[#18171F]/90 px-6 py-8 md:px-8 md:py-10 flex flex-col">

        <h2 class="text-2xl md:text-3xl font-bold mb-1 text-center md:text-left">Create your account</h2>
        <p class="text-xs md:text-sm text-[#A39EB8] mb-6">Sign up to start booking stays or hosting.</p>

        <!-- ERROR MESSAGE -->
        <% if (errors && errors.length > 0) { %>
          <div
            class="mb-6 p-4 bg-[#F9737320] border border-[#F97373] text-[#F97373] rounded-xl text-sm shadow-md animate-[shake_0.35s]">
            <h4 class="font-semibold mb-2">Please fix the following:</h4>
            <ul class="list-disc list-inside space-y-1">
              <% errors.forEach(msg => { %>
                <li><%= msg %></li>
              <% }) %>
            </ul>
          </div>
        <% } %>

        <!-- FORM -->
        <form action="/signup" method="POST" class="space-y-5">

          <div class="flex flex-col md:flex-row gap-4">
            <div class="field-shell bg-[#0E0D13] border border-[#2D2A37] rounded-xl px-4 py-1">
              <input
                type="text"
                name="firstName"
                value="<%= oldInput.firstName %>"
                placeholder="First name"
                required
                class="w-full bg-transparent py-2.5 text-sm outline-none" />
            </div>

            <div class="field-shell bg-[#0E0D13] border border-[#2D2A37] rounded-xl px-4 py-1">
              <input
                type="text"
                name="lastName"
                value="<%= oldInput.lastName %>"
                placeholder="Last name"
                required
                class="w-full bg-transparent py-2.5 text-sm outline-none" />
            </div>
          </div>

          <div class="field-shell bg-[#0E0D13] border border-[#2D2A37] rounded-xl px-4 py-1">
            <input
              type="email"
              name="email"
              value="<%= oldInput.email %>"
              placeholder="Email address"
              required
              class="w-full bg-transparent py-2.5 text-sm outline-none" />
          </div>

          <!-- Passwords -->
          <div class="space-y-2">
            <div class="field-shell bg-[#0E0D13] border border-[#2D2A37] rounded-xl px-4 py-1 relative">
              <input
                id="password"
                type="password"
                name="password"
                value="<%= oldInput.password %>"
                placeholder="Password"
                required
                class="w-full bg-transparent py-2.5 pr-10 text-sm outline-none" />
              <button
                type="button"
                id="togglePassword"
                class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-[#8C5FF6] hover:text-[#F43F63]">
                Show
              </button>
            </div>
            <div class="h-1.5 bg-[#1E1B2A] rounded-full overflow-hidden">
              <div
                id="passwordStrengthBar"
                class="h-full w-0 rounded-full strength-weak transition-all duration-300 ease-out">
              </div>
            </div>
            <p id="passwordStrengthText" class="text-[11px] text-[#A39EB8]"></p>
          </div>

          <div class="space-y-1">
            <div class="field-shell bg-[#0E0D13] border border-[#2D2A37] rounded-xl px-4 py-1 relative">
              <input
                id="confirmPassword"
                type="password"
                name="confirmPassword"
                placeholder="Confirm password"
                required
                class="w-full bg-transparent py-2.5 pr-10 text-sm outline-none" />
              <button
                type="button"
                id="toggleConfirmPassword"
                class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-[#8C5FF6] hover:text-[#F43F63]">
                Show
              </button>
            </div>
            <p id="confirmPasswordText" class="text-[11px] text-[#F97373] hidden">
              Passwords do not match.
            </p>
          </div>

          <!-- USER TYPE -->
          <p class="text-xs uppercase font-medium text-[#C9C5D4]">Register as</p>
          <input
            type="hidden"
            id="userType"
            name="userType"
            value="<%= oldInput.userType %>" />

          <div class="grid grid-cols-2 gap-3">
            <button
              type="button"
              id="roleGuest"
              class="role-card flex flex-col items-center gap-2 border rounded-2xl px-4 py-3 text-sm transition
              <%= oldInput.userType === 'guest' ? 'role-card-active' : '' %>">
              👤 <span class="font-semibold">Guest</span>
              <span class="text-[11px] text-[#A39EB8]">Book stays</span>
            </button>

            <button
              type="button"
              id="roleHost"
              class="role-card flex flex-col items-center gap-2 border rounded-2xl px-4 py-3 text-sm transition
              <%= oldInput.userType === 'host' ? 'role-card-active' : '' %>">
              🏠 <span class="font-semibold">Host</span>
              <span class="text-[11px] text-[#A39EB8]">List properties</span>
            </button>
          </div>

          <!-- TERMS -->
          <label class="flex items-start gap-3 text-xs cursor-pointer">
            <input type="checkbox" name="terms" class="mt-[2px] w-4 h-4 accent-[#8C5FF6]" />
            <span>
              I agree to the <a class="text-[#8C5FF6]">Terms</a> &amp;
              <a class="text-[#8C5FF6]">Privacy Policy</a>.
            </span>
          </label>

          <!-- SUBMIT -->
          <button
            type="submit"
            class="w-full py-3 bg-gradient-to-r from-[#8C5FF6] to-[#F43F63] rounded-xl text-white font-semibold shadow-xl hover:scale-[1.02] active:scale-[0.97] transition">
            Create account
          </button>

        </form>

        <p class="text-center text-[#A39EB8] text-xs mt-6">
          Already have an account?
          <a href="/login" class="text-[#8C5FF6] font-semibold">Login instead</a>
        </p>

      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>

  <script>
    // --- Element refs ---
    const passwordInput = document.getElementById("password");
    const confirmInput = document.getElementById("confirmPassword");
    const strengthBar = document.getElementById("passwordStrengthBar");
    const strengthText = document.getElementById("passwordStrengthText");
    const confirmText = document.getElementById("confirmPasswordText");

    const togglePasswordBtn = document.getElementById("togglePassword");
    const toggleConfirmBtn = document.getElementById("toggleConfirmPassword");

    const roleGuest = document.getElementById("roleGuest");
    const roleHost = document.getElementById("roleHost");
    const userTypeInput = document.getElementById("userType");

    // --- Password strength ---
    function evaluateStrength(value) {
      let score = 0;
      if (value.length >= 8) score++;
      if (value.length >= 12) score++;
      if (/[A-Z]/.test(value)) score++;
      if (/[0-9]/.test(value)) score++;
      if (/[^A-Za-z0-9]/.test(value)) score++;
      return score;
    }

    function updateStrength() {
      const val = passwordInput.value || "";
      const score = evaluateStrength(val);

      let width = "0%";
      let label = "";
      let cls = "strength-weak";

      if (!val) {
        width = "0%";
        label = "";
      } else if (score <= 2) {
        width = "35%";
        label = "Weak – use at least 8 characters with numbers & symbols.";
        cls = "strength-weak";
      } else if (score === 3 || score === 4) {
        width = "70%";
        label = "Medium – add more length or variety for stronger security.";
        cls = "strength-medium";
      } else {
        width = "100%";
        label = "Strong password ✅";
        cls = "strength-strong";
      }

      strengthBar.style.width = width;
      strengthBar.classList.remove("strength-weak", "strength-medium", "strength-strong");
      strengthBar.classList.add(cls);
      strengthText.textContent = label;

      checkConfirmMatch();
    }

    passwordInput.addEventListener("input", updateStrength);

    // --- Confirm password match ---
    function checkConfirmMatch() {
      const pass = passwordInput.value;
      const conf = confirmInput.value;

      if (!conf) {
        confirmText.classList.add("hidden");
        confirmText.classList.remove("text-emerald-400");
        confirmText.classList.add("text-[#F97373]");
        return;
      }

      if (conf !== pass) {
        confirmText.textContent = "Passwords do not match.";
        confirmText.classList.remove("hidden");
        confirmText.classList.remove("text-emerald-400");
        confirmText.classList.add("text-[#F97373]");
      } else {
        confirmText.textContent = "Passwords match ✅";
        confirmText.classList.remove("hidden");
        confirmText.classList.remove("text-[#F97373]");
        confirmText.classList.add("text-emerald-400");
      }
    }

    confirmInput.addEventListener("input", checkConfirmMatch);

    // --- Show / hide toggles ---
    togglePasswordBtn.addEventListener("click", () => {
      const isPassword = passwordInput.type === "password";
      passwordInput.type = isPassword ? "text" : "password";
      togglePasswordBtn.textContent = isPassword ? "Hide" : "Show";
    });

    toggleConfirmBtn.addEventListener("click", () => {
      const isPassword = confirmInput.type === "password";
      confirmInput.type = isPassword ? "text" : "password";
      toggleConfirmBtn.textContent = isPassword ? "Hide" : "Show";
    });

    // --- Role selection ---
    function setRole(role) {
      userTypeInput.value = role;
      roleGuest.classList.remove("role-card-active");
      roleHost.classList.remove("role-card-active");
      if (role === "guest") roleGuest.classList.add("role-card-active");
      else roleHost.classList.add("role-card-active");
    }

    roleGuest.addEventListener("click", () => setRole("guest"));
    roleHost.addEventListener("click", () => setRole("host"));
  </script>
</body>
</html>
