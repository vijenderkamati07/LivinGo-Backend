<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>airbnb|Home</title>
  <link rel="stylesheet" href="output.css" />
  <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
</head>

<body class="bg-gray-50 min-h-screen flex flex-col">

  <!-- Header (unchanged) -->
  <!-- NAVBAR -->
    <%- include('../partials/nav') %>

  <!-- Main Content -->
  <main class="flex flex-col items-center justify-center flex-1 text-center px-6 py-10 bg-gray-50">
    <h2 class="text-4xl md:text-5xl font-bold text-gray-800 mb-4">Here are our listed Homes</h2>
    <p class="text-lg text-gray-600 max-w-2xl mb-10">
      Explore cozy homes and unique stays around the world. Add your own listing or book your next trip with ease.
    </p>
    <a href="/host/add-home"
      class="bg-red-500 hover:bg-red-600 text-white font-semibold px-8 py-3 rounded-full shadow-md transition duration-200 mb-10">
      Add Your Home
    </a>

    <!-- Grid of Homes (layout kept, styling improved) -->
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 w-full max-w-6xl">
      <% homes.forEach(home=> { %>
        <article
          class="group bg-white rounded-2xl shadow-sm border border-gray-200 hover:shadow-xl hover:border-gray-300 transition duration-300 overflow-hidden text-left">

          <!-- Image -->
          <div class="relative h-56 w-full overflow-hidden">
            <img src="/uploads/<%= home.photo %>" alt="<%= home.houseName %>"
              class="w-full h-full object-cover transform group-hover:scale-105 transition duration-500" />
            <!-- subtle top gradient for readability -->
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/0 via-black/0 to-black/5">
            </div>
          </div>

          <!-- Info Section -->
          <div class="p-4">
            <div class="flex items-center justify-between gap-3 mb-1">
              <h3 class="text-base font-semibold text-gray-900 truncate max-w-[70%]">
                <%= home.houseName %>
              </h3>
              <span class="text-red-500 font-semibold shrink-0">
                ₹<%= home.price %><span class="text-xs text-gray-500">/night</span>
              </span>
            </div>

            <p class="mt-1 text-gray-600 text-sm flex items-center gap-1 truncate">
              <!-- location icon -->
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="1.6" class="w-4 h-4 text-red-500">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M12 21s-7-5.373-7-10a7 7 0 1114 0c0 4.627-7 10-7 10z" />
                <circle cx="12" cy="11" r="2.5" />
              </svg>
              <span class="truncate">
                <%= home.location %>
              </span>
            </p>

            <!-- Description: keep same data, just neater display -->
            <p class="mt-3 text-gray-500 text-sm">
              <%= home.description %>
            </p>
          </div>
        </article>
        <% }) %>
    </div>
  </main>

  <!-- Footer (unchanged) -->
  <footer class="bg-gray-100 border-t border-gray-200 mt-16">
    <div class="max-w-6xl mx-auto px-6 py-10 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8 text-gray-700">
      <div>
        <h3 class="font-semibold text-gray-800 mb-3">Support</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="#" class="hover:text-red-500 transition">Help Centre</a></li>
          <li><a href="#" class="hover:text-red-500 transition">AirCover</a></li>
          <li><a href="#" class="hover:text-red-500 transition">Cancellation Options</a></li>
          <li><a href="#" class="hover:text-red-500 transition">Safety Information</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-semibold text-gray-800 mb-3">Community</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="#" class="hover:text-red-500 transition">Airbnb.org</a></li>
          <li><a href="#" class="hover:text-red-500 transition">Disaster Relief Housing</a></li>
          <li><a href="#" class="hover:text-red-500 transition">Refugee Support</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-semibold text-gray-800 mb-3">Hosting</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/host/add-home" class="hover:text-red-500 transition">Become a Host</a></li>
          <li><a href="#" class="hover:text-red-500 transition">Host Resources</a></li>
          <li><a href="#" class="hover:text-red-500 transition">Responsible Hosting</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-semibold text-gray-800 mb-3">About</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="#" class="hover:text-red-500 transition">Newsroom</a></li>
          <li><a href="#" class="hover:text-red-500 transition">Learn about Airbnb</a></li>
          <li><a href="#" class="hover:text-red-500 transition">Careers</a></li>
          <li><a href="#" class="hover:text-red-500 transition">Investors</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-300 mt-6 py-4">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center text-sm text-gray-500 px-6">
        <p>© 2025 Airbnb Clone — Created for learning purpose.</p>
        <div class="flex items-center space-x-4 mt-2 md:mt-0">
          <a href="#" class="hover:text-red-500 transition">Privacy</a>
          <a href="#" class="hover:text-red-500 transition">Terms</a>
          <a href="#" class="hover:text-red-500 transition">Sitemap</a>
        </div>
      </div>
    </div>
  </footer>

</body>

</html>