<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>LivinGo | Find Your Stay</title>

  <link rel="stylesheet" href="/output.css" />
  <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
</head>

<body class="bg-[#0E0D13] text-[#E5E3F3] transition-all duration-300 ease-out">

  <!-- NAV -->
  <%- include('../partials/nav') %>

  <!-- HERO SECTION -->
  <section class="relative min-h-[70vh] flex flex-col justify-center items-center text-center px-6">
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_top,_#8C5FF620,_transparent_60%),radial-gradient(circle_at_bottom,_#F43F6320,_transparent_55%)]">
    </div>

    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1505691938895-1758d7feb511?auto=format&w=1600&q=90"
        class="w-full h-full object-cover opacity-[0.14]" />
    </div>

    <div class="relative max-w-3xl mx-auto space-y-6">
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight">
        Stay Smarter. <span class="text-[#8C5FF6]">Travel Better.</span>
      </h1>
      <p class="text-base md:text-lg text-[#C9C5D4]">
        Discover modern stays, cozy homes, and handpicked rentals around the world — all in one place.
      </p>

      <!-- Search Bar -->
      <form action="/search" method="GET"
        class="mt-4 bg-[#18171F] border border-[#2D2A37] w-full max-w-2xl mx-auto rounded-full shadow-lg flex items-center overflow-hidden transition-all duration-300 ease-out hover:border-[#8C5FF6]">
        <input name="location" placeholder="Where do you want to go?"
          class="flex-1 px-6 py-4 bg-transparent outline-none text-sm text-[#E5E3F3] placeholder:text-[#77708F]" />
        <button type="submit"
          class="px-8 py-3 bg-gradient-to-r from-[#8C5FF6] to-[#F43F63] text-white font-semibold text-sm mr-1 my-1 rounded-full ui-action">
          Search
        </button>
      </form>
    </div>
  </section>

  <!-- CATEGORY SLIDER -->
  <section class="max-w-7xl mx-auto px-6 py-10">
    <h2 class="text-lg font-semibold mb-4 text-[#C9C5D4]">Browse by category</h2>
    <div class="flex gap-5 overflow-x-auto pb-2">
      <% ["Resort","Apartment","Villas","Farmhouses","Hostels","Rooms"].forEach(category => { %>
      <button
        class="flex flex-col items-center gap-2 min-w-24 px-3 py-2 rounded-xl bg-[#18171F] border border-[#2D2A37] hover:border-[#8C5FF6] hover:bg-[#201F2A] ui-action">
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[#8C5FF6] to-[#F43F63] opacity-80"></div>
        <span class="text-xs md:text-sm font-medium text-[#E5E3F3]"><%= category %></span>
      </button>
      <% }) %>
    </div>
  </section>

  <!-- TOP PICKS -->
  <section class="max-w-7xl mx-auto px-6 py-10 space-y-6">
    <h2 class="text-2xl font-bold">Top Picks Near You</h2>
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
      <% homes.forEach(home => { %>
      <div
  class="home-card bg-[#18171F] rounded-2xl shadow-lg overflow-hidden border border-[#2D2A37] transition-all duration-300 cursor-pointer">

  <a href="/home/<%= home._id %>">
      <div class="relative h-52 overflow-hidden">
      <!-- Image -->
      <img
        src="/uploads/<%= home.photo %>"
        class="w-full h-full object-cover transition-all duration-500 home-img" />

      <!-- Location Tag -->
      <span
        class="absolute left-3 bottom-3 bg-black/60 text-white text-[11px] font-medium px-3 py-1 rounded-full backdrop-blur-lg border border-white/20 shadow-md z-20">
        <%= home.location %>
      </span>

      <!-- Wishlist -->
      <form action="/favourite" method="POST" class="absolute top-3 right-3 z-20">
        <input type="hidden" name="id" value="<%= home._id %>">
        <button
          type="submit"
          class="wishlist-btn w-9 h-9 rounded-full bg-[#0E0D13]/70 flex items-center justify-center backdrop-blur-md border border-[#2D2A37] transition cursor-pointer">
          <svg class="wishlist-icon w-5 h-5 transition-all duration-300 <% if(home.isFavourite){ %> active <% } %>"
            viewBox="0 0 24 24">
            <path fill="currentColor"
              d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 
              4.5 2.09C13.09 3.81 14.76 3 16.5 3c3.08 0 5.5 2.42 5.5 5.5 
              0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
          </svg>
        </button>
      </form>
    </div>
  </a>

  <div class="p-5 space-y-2">
    <h3 class="text-base font-semibold text-white"><%= home.houseName %></h3>
    <span class="text-sm font-semibold text-[#9FE4C7] block">₹<%= home.price %> / night</span>
    <p class="text-xs text-[#C9C5D4] line-clamp-2"><%= home.description %></p>
  </div>

  <a href="/home/<%= home._id %>"
    class="mx-5 mb-5 text-center block py-2 rounded-lg text-[#E5E3F3] font-medium border border-[#8C5FF6] transition duration-300 hover:bg-[#8C5FF6] hover:text-white">
    View Details
  </a>
</div>

      <% }) %>
    </div>
  </section>

  <!-- NEWSLETTER / CTA -->
  <section class="mt-16 py-14 px-6">
    <div
      class="max-w-4xl mx-auto rounded-2xl bg-gradient-to-r from-[#18171F] via-[#201F2A] to-[#18171F] border border-[#2D2A37] shadow-xl px-6 md:px-10 py-10 md:py-12 flex flex-col gap-5 items-center text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white">Never Miss New Listings</h2>
      <p class="text-sm md:text-base text-[#C9C5D4] max-w-xl">
        Get email alerts when new homes are added in your favorite locations. No spam — only good stays.
      </p>
      <form action="/subscribe" method="POST" class="w-full max-w-xl flex flex-col sm:flex-row gap-3">
        <input name="email" placeholder="Enter your email"
          class="flex-1 rounded-lg px-4 py-3 bg-[#0E0D13] border border-[#2D2A37] text-sm text-[#E5E3F3] placeholder:text-[#6E6782] outline-none" />
        <button type="submit"
          class="bg-gradient-to-r from-[#8C5FF6] to-[#F43F63] text-white font-semibold px-6 py-3 rounded-lg ui-action">
          Subscribe
        </button>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <%- include('../partials/footer') %>
</body>

</html>
