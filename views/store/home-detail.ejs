<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= home.houseName %> | LivinGo</title>

  <link rel="stylesheet" href="/output.css">
  <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png">

  <!-- Leaflet Map -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

  <!-- Date Picker -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

  <style>
    .flatpickr-calendar { background:#18171F !important;border:1px solid #2D2A37 !important;box-shadow:0 0 20px #8C5FF620 !important;border-radius:14px !important;}
    .flatpickr-day { color:#C9C5D4 !important;}
    .flatpickr-day:hover { background:#8C5FF650 !important;color:white !important;}
    .flatpickr-day.selected,.flatpickr-day.startRange,.flatpickr-day.endRange {background:linear-gradient(90deg,#8C5FF6,#F43F63) !important;border:none !important;color:white !important;}
    .flatpickr-current-month input.cur-year {color:white !important;}
    .flatpickr-monthDropdown-months,.flatpickr-weekday {color:#E5E3F3 !important;}
    .guest-popover {background:#18171F;border:1px solid #2D2A37;box-shadow:0 18px 45px #000000aa;border-radius:18px;}

    .review-slider{position:relative;height:260px;}
    @media(min-width:768px){.review-slider{height:300px;}}
    .reviewCard{position:absolute;top:50%;left:50%;width:80%;max-width:36rem;transform:translate(-50%,-50%) scale(0.7);opacity:0;filter:blur(3px);transition:0.4s;z-index:1;}
    .reviewCard.center{transform:translate(-50%,-50%) scale(1);opacity:1;filter:blur(0);z-index:10;}
    .reviewCard.left{transform:translate(-130%,-50%) scale(.75);opacity:.4;filter:blur(2px);z-index:5;}
    .reviewCard.right{transform:translate(30%,-50%) scale(.75);opacity:.4;filter:blur(2px);z-index:5;}
    .reviewCard.hidden-card{opacity:0;filter:blur(4px);z-index:1;pointer-events:none;}
  </style>
</head>

<body class="bg-[#0E0D13] text-[#E5E3F3] min-h-screen flex flex-col">
  <%- include('../partials/nav') %>

  <main class="flex-1">

    <!-- GALLERY -->
    <section class="max-w-6xl mx-auto px-6 pt-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 rounded-xl overflow-hidden">
        <div class="h-[420px] rounded-xl overflow-hidden cursor-pointer galleryItem">
          <img src="<%= home.photo %>" class="w-full h-full object-cover rounded-xl" />
        </div>
        <div class="grid grid-cols-2 gap-4 h-[420px]">
          <% [
            "https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&w=900&q=80",
            "https://images.unsplash.com/photo-1507089947368-19c1da9775ae?auto=format&w=900&q=80",
            "https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&w=900&q=80",
            "https://images.unsplash.com/photo-1600585154340-be6161a560c?auto=format&w=900&q=80"
          ].forEach(img => { %>
            <img src="<%= img %>" class="w-full h-full object-cover rounded-xl cursor-pointer galleryItem">
          <% }) %>
        </div>
      </div>
    </section>

    <!-- CONTENT + SIDEBAR -->
    <section class="max-w-6xl mx-auto px-6 py-10 flex flex-col lg:flex-row gap-12">
      <div class="flex-1">
        <span class="px-4 py-1 text-sm rounded-full bg-[#1A1824] border border-[#8C5FF6] text-[#C9C5D4]"><%= home.category %></span>
        <h1 class="text-4xl font-extrabold mt-4 mb-2"><%= home.houseName %></h1>

        <div class="flex items-center justify-between mt-3 mb-6 flex-wrap gap-3">
          <div class="flex items-center gap-2 text-[#C9C5D4] text-lg">
            <svg class="w-6 h-6 text-[#8C5FF6]" fill="currentColor"><path d="M12 2C8 2 5 5 5 9c0 5 7 13 7 13s7-8 7-13c0-4-3-7-7-7zm0 9a2.5 2.5 0 110-5 2.5 2.5 0 010 5z"/></svg>
            <%= home.location %>
          </div>
          <a href="/favourite" class="fav-btn px-4 py-2 flex items-center gap-2 border border-[#8C5FF6] text-[#F43F63] rounded-xl font-medium">❤️ Add to Favourite</a>
        </div>

        <h2 class="text-2xl font-semibold mb-3">About this place</h2>
        <p class="text-[#C9C5D4] leading-relaxed text-lg mb-8"><%= home.description %></p>

        <h2 class="text-2xl font-semibold mb-4">Location</h2>
        <div id="map" class="h-64 w-full rounded-xl shadow-xl"></div>
      </div>

      <!-- SIDEBAR -->
      <div class="w-full lg:w-80 bg-[#18171F] border border-[#2D2A37] shadow-xl p-6 rounded-2xl h-fit sticky top-[100px]">
        <p class="text-3xl font-bold">₹<%= home.price %></p>
        <p class="text-[#C9C5D4] text-sm mb-5">per night</p>

        <div class="grid grid-cols-2 gap-3 mb-3">
          <input id="checkin" placeholder="Check-in" class="dp-input bg-[#0E0D13] text-[#E5E3F3] px-4 py-3 rounded-xl border border-[#2D2A37]">
          <input id="checkout" placeholder="Check-out" class="dp-input bg-[#0E0D13] text-[#E5E3F3] px-4 py-3 rounded-xl border border-[#2D2A37]">
        </div>

        <!-- GUEST PICKER -->
        <div class="relative mb-4">
          <button id="guestPickerBtn" class="w-full flex items-center justify-between bg-[#0E0D13] px-4 py-3 rounded-xl border border-[#2D2A37]">
            <span id="guestPickerLabel">1 Guest</span>
            <svg class="w-5 h-5 text-[#8C5FF6]" fill="none" stroke="currentColor"><path d="M19 9l-7 7-7-7" /></svg>
          </button>
          <input type="hidden" id="guestValue" value="1">
          <div id="guestPopover" class="guest-popover absolute left-0 right-0 mt-2 p-4 hidden z-20">
            <div class="flex items-center justify-between mb-3">
              <span class="text-sm">Guests</span>
              <span id="guestCountText" class="text-sm font-semibold text-white">1</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm">Total guests</span>
              <div class="flex items-center gap-3">
                <button id="guestMinus" class="w-8 h-8 rounded-full border">-</button>
                <span id="guestCount" class="w-6 text-center font-semibold">1</span>
                <button id="guestPlus" class="w-8 h-8 rounded-full border">+</button>
              </div>
            </div>
            <button id="guestApply" class="mt-4 w-full py-2 rounded-xl bg-gradient-to-r from-[#8C5FF6] to-[#F43F63] text-white">Apply</button>
          </div>
        </div>

        <a href="#" class="block bg-gradient-to-r from-[#8C5FF6] to-[#F43F63] text-white text-lg font-semibold text-center py-3 rounded-xl">Book Now</a>
        <p class="text-xs text-[#7F7A95] text-center mt-3">You won't be charged yet</p>
      </div>
    </section>

    <!-- AMENITIES -->
    <section class="max-w-6xl mx-auto px-6 mt-14">
      <h2 class="text-2xl font-semibold mb-5">Amenities</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <% [
        "Free Wi-Fi","Air Conditioning","Power Backup","Hot Water","Smart TV","Kitchen Access",
        "Parking Available","Pet Friendly","24/7 Security"
        ].forEach(a => { %>
          <div class="flex items-center gap-3 bg-[#18171F] border border-[#2D2A37] py-3 px-4 rounded-xl">
            <svg class="w-5 h-5 text-[#8C5FF6]" fill="none" stroke="currentColor"><path d="M5 13l4 4L19 7" /></svg>
            <%= a %>
          </div>
        <% }) %>
      </div>
    </section>

    <!-- REVIEWS -->
    <section class="max-w-6xl mx-auto px-6 mt-16 text-center">
      <h2 class="text-2xl font-semibold mb-10">Guest Reviews</h2>

      <div class="relative max-w-3xl mx-auto">
        <div id="reviewSlider" class="review-slider flex items-center justify-center overflow-visible">
          <% [
            {name:"Ujjwal",review:"Amazing stay! Clean rooms, great location and fast Wi-Fi. Definitely worth it."},
            {name:"Ashwani",review:"Loved the cozy interior and the host was very helpful. Will return soon!"},
            {name:"Rupan",review:"Perfect for family trips - spacious and peaceful neighborhood."},
            {name:"Parkash",review:"Very clean & quick check-in process, the host was extremely polite."},
            {name:"Rohit",review:"Very clean & quick check-in process, the host was extremely polite."},

          ].forEach((r,i)=>{ %>
            <div class="reviewCard bg-[#18171F] border border-[#2D2A37] p-7 rounded-2xl shadow" data-index="<%= i %>">
              <p class="text-xl font-semibold mb-3 text-white"><%= r.name %></p>
              <p class="text-lg leading-relaxed text-[#C9C5D4]"><%= r.review %></p>
            </div>
          <% }) %>
        </div>

        <button id="prevReview"
  class="absolute left-0 top-1/2 -translate-y-1/2 px-4 py-2 text-3xl text-[#8C5FF6] hover:text-white z-50 cursor-pointer">
  ❮
</button>

<button id="nextReview"
  class="absolute right-0 top-1/2 -translate-y-1/2 px-4 py-2 text-3xl text-[#8C5FF6] hover:text-white z-50 cursor-pointer">
  ❯
</button>

      </div>
    </section>

    <!-- HOST -->
    <section class="max-w-6xl mx-auto px-6 mt-16 mb-20">
      <h2 class="text-2xl font-semibold mb-5">Meet Your Host</h2>
      <div class="flex flex-col md:flex-row gap-6 items-center bg-[#18171F] border border-[#2D2A37] p-6 rounded-2xl shadow">
        <div class="w-20 h-20 rounded-full bg-gradient-to-br from-[#8C5FF6] to-[#F43F63] flex items-center justify-center text-3xl font-bold text-white">
          M
        </div>
        <div class="flex-1 text-center md:text-left">
          <p class="text-xl font-semibold">Manish Singh</p>
          <p class="text-sm text-[#9D99B0]">Hosting since 2022 • Speaks English & Hindi</p>
          <p class="text-sm text-[#9D99B0] mt-1">Response rate: <span class="text-white font-semibold">98%</span></p>
          <span class="inline-block mt-3 px-3 py-1 rounded-full text-xs font-semibold bg-[#2A2638] text-[#C9C5D4] border border-[#8C5FF6]">
            ⭐ Superhost
          </span>
        </div>
        <a href="#" class="host-btn px-4 py-2 flex items-center gap-2 border border-[#8C5FF6] text-white rounded-xl font-medium">
          Contact Host
        </a>
      </div>
    </section>

  </main>

  <%- include('../partials/footer') %>

  <!-- MAP -->
  <script>
    const map = L.map("map").setView([<%= home.lat %>, <%= home.lng %>], 13);
    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png").addTo(map);
    L.marker([<%= home.lat %>, <%= home.lng %>]).addTo(map).bindPopup("<%= home.houseName %>");
  </script>

  <!-- DATE PICKERS -->
  <script>
    const checkout = flatpickr("#checkout", { dateFormat:"d-m-Y", minDate:"today" });
    flatpickr("#checkin", {
      dateFormat: "d-m-Y",
      minDate: "today",
      onChange: dates => checkout.set("minDate", dates[0])
    });
  </script>

  <!-- GUEST PICKER -->
  <script>
    let guestCount = 1;
    const guestPickerBtn = document.getElementById("guestPickerBtn");
    const guestPopover = document.getElementById("guestPopover");
    const guestLabel = document.getElementById("guestPickerLabel");
    const guestValue = document.getElementById("guestValue");
    const guestCountText = document.getElementById("guestCount");
    const guestCountOut = document.getElementById("guestCountText");
    function update(){ guestCountText.textContent=guestCount; guestCountOut.textContent=guestCount; guestValue.value=guestCount; guestLabel.textContent=guestCount===1?"1 Guest":`${guestCount} Guests`; }
    guestPickerBtn.onclick = e => (e.stopPropagation(), guestPopover.classList.toggle("hidden"));
    document.getElementById("guestMinus").onclick = () => (guestCount>1 && guestCount--, update());
    document.getElementById("guestPlus").onclick = () => (guestCount<4 && guestCount++, update());
    document.getElementById("guestApply").onclick = () => guestPopover.classList.add("hidden");
    document.addEventListener("click", e => !guestPopover.contains(e.target) && !guestPickerBtn.contains(e.target) && guestPopover.classList.add("hidden"));
    update();
  </script>

  <!-- REVIEW SLIDER -->
  <script>
    const cards=document.querySelectorAll(".reviewCard");
    let idx=0;
    function show(){
      cards.forEach((c,i)=>{
        c.classList.remove("center","left","right","hidden-card");
        if(i===idx) c.classList.add("center");
        else if(i===(idx-1+cards.length)%cards.length) c.classList.add("left");
        else if(i===(idx+1)%cards.length) c.classList.add("right");
        else c.classList.add("hidden-card");
      });
    }
    document.getElementById("prevReview").onclick=()=>{ idx=(idx-1+cards.length)%cards.length; show(); };
    document.getElementById("nextReview").onclick=()=>{ idx=(idx+1)%cards.length; show(); };
    show();
  </script>

</body>
</html>
